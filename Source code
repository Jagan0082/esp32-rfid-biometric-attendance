                       int httpCode, int attendResult) {
  printDoubleSeparator();
  Serial.println("  >>> ATTENDANCE EVENT DETAILS <<<");
  printSeparator();
  Serial.print("  Scan #            : "); Serial.println(totalScans);
  Serial.print("  Event time (local): ");
  time_t ts = (e.timestamp_utc > 100000) ? e.timestamp_utc : time(nullptr);
  struct tm t; localtime_r(&ts, &t);
  char buf[32]; strftime(buf, sizeof(buf), "%d/%m/%Y %I:%M:%S %p", &t);
  Serial.println(buf);
  Serial.print("  Identity type     : "); Serial.println(e.type == ID_RFID ? "RFID" : "FINGERPRINT");
  Serial.print("  Raw ID            : "); Serial.println(e.raw_id);
  Serial.print("  Identified        : "); Serial.println(identified ? "YES" : "NO");
  if (identified) {
    Serial.print("  User ID           : "); Serial.println(userId);
    Serial.print("  Name              : "); Serial.println(userName);
    Serial.print("  Scan count        : "); Serial.println(scanCount);
    Serial.print("  Greeting          : "); Serial.println(greeting);
    Serial.print("  Attendance send   : HTTP "); Serial.println(attendResult);
  } else {
    Serial.print("  HTTP code         : "); Serial.println(httpCode);
    if (WiFi.status() != WL_CONNECTED)
      Serial.println("  Offline save      : YES (WiFi lost)");
    else if (httpCode != 404)
      Serial.println("  Offline save      : YES (server error)");
    else
      Serial.println("  Offline save      : NO (unknown ID)");
  }
  printDoubleSeparator();
  Serial.println();
}

// ==================== PROCESS EVENT ====================
void processEvent(IdentityEvent e) {
  totalScans++;
  printSeparator();
  Serial.println("[Event] Processing scan #" + String(totalScans));
  showAlert("Identifying...", "Please wait", true);
  String userId, userName, greeting = "Welcome";
  int scanCount = 1, httpCode = 0;
  bool identified = identifyUser(e, userId, userName, scanCount, greeting, httpCode);
  int attendResult = -1;
  if (identified) {
    successfulScans++;
    time_t ts = (e.timestamp_utc > 100000) ? e.timestamp_utc : time(nullptr);
    bool isWelcome;
    if      (greeting == "Welcome"  || greeting == "WELCOME")   isWelcome = true;
    else if (greeting == "Thank You"|| greeting == "THANK YOU") isWelcome = false;
    else                                                       isWelcome = (scanCount % 2 == 1);
    const char* greetLine = isWelcome ? "Welcome!" : "Thank You!";
    Serial.println("[Event] >>> " + (String)greetLine + " " + userName +
                   "  scan#" + String(scanCount) +
                   "  (" + (String)(isWelcome ? "CHECK-IN" : "CHECK-OUT") + ")");
    showGreeting(greetLine, userName.c_str(), isWelcome, scanCount);
    if (isWelcome) beepAsyncSingle(BEEP_WELCOME);
    else beepAsyncDouble(BEEP_THANKYOU_1, BEEP_THANKYOU_GAP, BEEP_THANKYOU_2);
    attendResult = sendAttendance(userId, ts);
  } else {
    failedScans++;
    Serial.println("[Event] Access Denied — unknown ID");
    showAlert("Access Denied", "Unknown ID", false);
    beepAsyncSingle(BEEP_ERROR);
    if (WiFi.status() != WL_CONNECTED) {
      e.retryCount = 0;
      saveEventToPreferences(e);
      Serial.println("[Event] Event saved offline (WiFi lost)");
    } else if (httpCode != 404) {
      e.retryCount = 0;
      saveEventToPreferences(e);
      Serial.println("[Event] Event saved offline (server error " + String(httpCode) + ")");
    } else {
      Serial.println("[Event] Event not saved (unknown ID, server returned 404)");
    }
  }
  printEventDetails(e, userId, userName, scanCount, greeting, identified, httpCode, attendResult);
  printSeparator();
}

// ==================== SCANNER LOOP (fingerprint uses local matching) ====================
void scannerLoop() {
  if (enrollActive || rfidEnrollActive) return;
  unsigned long now = millis();
  // RFID
  String rfidID = getRFID();
  if (rfidID.length()>0 && now-lastScanTime>=SCAN_COOLDOWN) {
    Serial.println("[Scanner] RAW RFID capture: " + rfidID);
    IdentityEvent e = {ID_RFID, rfidID, now, time(nullptr), false, 0};
    if (enqueueEvent(e)) {
      lastScanTime=now; beepAsyncSingle(BEEP_SCAN);
      Serial.println("[Scanner] RFID queued: " + rfidID);
    }
  }
  // Fingerprint - LOCAL matching (offline capable)
  String fpID = getFingerprintID();  // uses fingerSearch() - local sensor DB
  if (fpID.length()>0 && now-lastScanTime>=SCAN_COOLDOWN) {
    Serial.println("[Scanner] RAW fingerprint capture ID: " + fpID);
    IdentityEvent e = {ID_FINGERPRINT, fpID, now, time(nullptr), false, 0};
    if (enqueueEvent(e)) {
      lastScanTime=now; beepAsyncSingle(BEEP_SCAN);
      Serial.println("[Scanner] FP queued ID: " + fpID);
    }
  }
}

// ==================== WIFI ====================
void connectWiFi() {
  printSeparator();
  Serial.println("[WiFi] Connecting: "+String(ssid));
  tft.fillRect(0,MID_Y,SCREEN_W,MID_H,CLR_MID_BG);
  tft.setTextColor(TFT_WHITE,CLR_MID_BG); tft.setTextSize(2);
  tft.setCursor(20,MID_Y+30); tft.print("Connecting WiFi...");
  tft.setCursor(20,MID_Y+55); tft.print(ssid);
  WiFi.begin(ssid,password);
  int att=0;
  while (WiFi.status()!=WL_CONNECTED&&att<20){delay(500);att++;Serial.print(".");}
  Serial.println();
  tft.fillRect(0,MID_Y,SCREEN_W,MID_H,CLR_MID_BG);
  if (WiFi.status()==WL_CONNECTED) {
    Serial.println("[WiFi] Connected!  IP: "+WiFi.localIP().toString());
    tft.setTextColor(TFT_GREEN,CLR_MID_BG);
    tft.setCursor(20,MID_Y+30); tft.print("WiFi Connected!");
    tft.setTextColor(TFT_WHITE,CLR_MID_BG);
    tft.setCursor(20,MID_Y+55); tft.print(WiFi.localIP().toString());
    syncTime(); sendStoredEvents();
  } else {
    Serial.println("[WiFi] FAILED — offline mode");
    tft.setTextColor(TFT_RED,CLR_MID_BG);
    tft.setCursor(20,MID_Y+40); tft.print("WiFi Failed (offline)");
  }
  printSeparator(); delay(800);
}

void syncTime() {
  Serial.println("[NTP] Syncing...");
  configTime(gmtOffset_sec,daylightOffset_sec,ntpServer);
  time_t now=time(nullptr); int retry=0;
  while (now<100000&&retry<20){delay(500);now=time(nullptr);retry++;}
  if (retry<20) {
    struct tm t; localtime_r(&now,&t);
    char buf[32]; strftime(buf,sizeof(buf),"%d/%m/%Y %I:%M:%S %p",&t);
    Serial.println("[NTP] Synced: "+String(buf));
  } else { Serial.println("[NTP] Sync failed"); }
}

// ==================== DEVICE ID ====================
String generateDeviceID() {
  uint8_t mac[6];
  WiFi.macAddress(mac);
  char buf[13];
  sprintf(buf, "%02X%02X%02X%02X%02X%02X",
          mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);
  return String(buf);
}

void loadOrCreateDeviceID() {
  preferences.begin("device",false);
  if (preferences.isKey("id")) {
    deviceID=preferences.getString("id");
    Serial.println("[Device] Loaded ID: "+deviceID);
  } else {
    deviceID=generateDeviceID();
    preferences.putString("id",deviceID);
    Serial.println("[Device] Generated ID: "+deviceID);
  }
  preferences.end();
}

