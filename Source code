void saveEventToPreferences(const IdentityEvent& e) {
  preferences.begin("events", false);
  int cnt = preferences.getInt("count", 0);
  if (cnt < MAX_STORED_EVENTS) {
    String key  = "ev" + String(cnt);
    String data = String((int)e.type) + "|" + e.raw_id + "|" +
                  String(e.timestamp_ms) + "|" + String((long)e.timestamp_utc) + "|" +
                  String(e.retryCount);
    preferences.putString(key.c_str(), data);
    preferences.putInt("count", cnt+1);
    offlineSaved++;
    Serial.println("[Offline] Saved: " + data + "  total=" + String(cnt+1));
  } else { Serial.println("[Offline] Storage FULL"); }
  preferences.end();
}

void sendStoredEvents() {
  if (WiFi.status() != WL_CONNECTED) return;
  preferences.begin("events", false);
  int cnt = preferences.getInt("count", 0);
  if (cnt == 0) { preferences.end(); return; }
  Serial.println("[Offline] Syncing " + String(cnt) + " event(s)...");
  for (int i = 0; i < cnt; ) {
    String key  = "ev" + String(i);
    String data = preferences.getString(key.c_str(), "");
    if (data.length() == 0) { i++; continue; }
    int s1 = data.indexOf('|');
    int s2 = data.indexOf('|', s1+1);
    int s3 = data.indexOf('|', s2+1);
    int s4 = data.indexOf('|', s3+1);
    if (s1<0||s2<0||s3<0||s4<0) {
      for (int j=i;j<cnt-1;j++)
        preferences.putString(("ev"+String(j)).c_str(),
          preferences.getString(("ev"+String(j+1)).c_str(),""));
      preferences.remove(("ev"+String(cnt-1)).c_str());
      cnt--; preferences.putInt("count",cnt); continue;
    }
    IdentityEvent e;
    e.type          = (IdentityType)data.substring(0,s1).toInt();
    e.raw_id        = data.substring(s1+1,s2);
    e.timestamp_ms  = data.substring(s2+1,s3).toInt();
    e.timestamp_utc = (time_t)data.substring(s3+1,s4).toInt();
    e.retryCount    = (uint8_t)data.substring(s4+1).toInt();
    e.sent = false;
    String userId,userName,greeting; int scanCount=1,httpCode;
    bool identified = identifyUser(e,userId,userName,scanCount,greeting,httpCode);
    if (identified) {
      sendAttendance(userId,e.timestamp_utc>100000?e.timestamp_utc:(time_t)e.timestamp_ms);
      for(int j=i;j<cnt-1;j++)
        preferences.putString(("ev"+String(j)).c_str(),
          preferences.getString(("ev"+String(j+1)).c_str(),""));
      preferences.remove(("ev"+String(cnt-1)).c_str());
      cnt--; preferences.putInt("count",cnt);
      Serial.println("[Offline] Event sent and removed.");
    } else {
      if (httpCode==404) {
        Serial.println("[Offline] Unknown ID, deleting.");
        for(int j=i;j<cnt-1;j++)
          preferences.putString(("ev"+String(j)).c_str(),
            preferences.getString(("ev"+String(j+1)).c_str(),""));
        preferences.remove(("ev"+String(cnt-1)).c_str());
        cnt--; preferences.putInt("count",cnt);
      } else {
        e.retryCount++;
        if (e.retryCount>=5) {
          Serial.println("[Offline] Max retries, deleting.");
          for(int j=i;j<cnt-1;j++)
            preferences.putString(("ev"+String(j)).c_str(),
              preferences.getString(("ev"+String(j+1)).c_str(),""));
          preferences.remove(("ev"+String(cnt-1)).c_str());
          cnt--; preferences.putInt("count",cnt);
        } else {
          String nd = String((int)e.type)+"|"+e.raw_id+"|"+
                      String(e.timestamp_ms)+"|"+String((long)e.timestamp_utc)+"|"+
                      String(e.retryCount);
          preferences.putString(key.c_str(),nd); i++;
        }
      }
    }
  }
  preferences.end();
  Serial.println("[Offline] Sync complete");
}

// ==================== IDENTIFY USER (online, but fingerprint uses local ID) ====================
bool identifyUser(IdentityEvent& event, String& userId, String& userName,
                  int& scanCount, String& greeting, int& httpCode) {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[Identify] WiFi not connected"); httpCode=-1; return false;
  }
  Serial.print("[Identify] type=");
  Serial.print(event.type==ID_RFID?"RFID":"FINGERPRINT");
  Serial.println("  rawId="+event.raw_id);
  HTTPClient http;
  http.begin(String(serverUrl)+"/api/identify.php");
  http.addHeader("Content-Type","application/json");
  StaticJsonDocument<200> doc;
  doc["deviceId"]  = deviceID;
  doc["type"]      = (event.type==ID_RFID)?"rfid":"fingerprint";
  doc["rawId"]     = event.raw_id;
  doc["timestamp"] = (event.timestamp_utc>100000)?event.timestamp_utc:event.timestamp_ms;
  String payload; serializeJson(doc,payload);
  Serial.println("[Identify] POST: "+payload);
  int code = http.POST(payload);
  String body = http.getString();
  httpCode = code;
  Serial.printf("[Identify] HTTP %d  body: %s\n",code,body.c_str());
  if (code==200) {
    StaticJsonDocument<256> res;
    if (!deserializeJson(res,body) && res.containsKey("userId")) {
      userId    = res["userId"].as<String>();
      userName  = res["name"].as<String>();
      scanCount = res["scanCount"]|1;
      String g  = res["greeting"].as<String>();
      greeting  = (g.length()>0)?g:((scanCount%2==1)?"Welcome":"Thank You");
      Serial.println("[Identify] Found: "+userName+"  scan#"+String(scanCount)+
                     "  greeting="+greeting);
      http.end(); return true;
    }
  } else if (code==404) {
    Serial.println("[Identify] Unknown identity");
  } else {
    Serial.println("[Identify] Server error HTTP "+String(code));
  }
  http.end(); return false;
}

// ==================== SEND ATTENDANCE ====================
int sendAttendance(String userId, time_t timestamp) {
  if (WiFi.status()!=WL_CONNECTED) {
    Serial.println("[Attend] WiFi not connected"); return -1;
  }
  char tsBuf[32]; struct tm ts; localtime_r(&timestamp,&ts);
  strftime(tsBuf,sizeof(tsBuf),"%d/%m/%Y %I:%M:%S %p",&ts);
  Serial.println("[Attend] userId="+userId+"  time="+String(tsBuf));
  HTTPClient http;
  http.begin(String(serverUrl)+"/api/record_attendance.php");
  http.addHeader("Content-Type","application/json");
  StaticJsonDocument<200> doc;
  doc["userId"]    = userId;
  doc["timestamp"] = (long)timestamp;
  doc["deviceId"]  = deviceID;
  String payload; serializeJson(doc,payload);
  int code = http.POST(payload);
  String body = http.getString();
  Serial.printf("[Attend] HTTP %d  body: %s\n",code,body.c_str());
  int sc=1;
  if (code==200) {
    StaticJsonDocument<200> res;
    if (!deserializeJson(res,body)&&res.containsKey("scanCount"))
      sc=res["scanCount"].as<int>();
  }
  http.end(); return sc;
}

