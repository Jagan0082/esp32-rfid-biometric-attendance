// ==================== RESTORE FINGERPRINTS FROM DB (with version) ====================
void restoreFingerprintsFromDB() {
  if (WiFi.status() != WL_CONNECTED) {
    Serial.println("[Restore] WiFi not connected — aborting"); return;
  }
  Serial.println("[Restore] Fetching templates from DB...");
  showAlert("Syncing...", "Please wait", true);
  HTTPClient http;
  http.begin(String(serverUrl) + "/api/enroll_fingerprint.php?restore=1");
  http.setTimeout(20000);
  int code = http.GET();
  if (code != 200) {
    Serial.printf("[Restore] Server error HTTP %d\n", code); http.end();
    showAlert("Sync Fail", "Server error", false);
    beepAsyncSingle(BEEP_ERROR); return;
  }
  String body = http.getString(); http.end();
  DynamicJsonDocument doc(65536);
  DeserializationError err = deserializeJson(doc, body);
  if (err) {
    Serial.println("[Restore] JSON parse failed: " + String(err.c_str()));
    showAlert("Sync Fail", "Parse error", false);
    beepAsyncSingle(BEEP_ERROR); return;
  }
  if (!doc["restore"].as<bool>()) {
    Serial.println("[Restore] No templates in DB");
    showAlert("Sync", "No templates", false);
    beepAsyncSingle(BEEP_ERROR); return;
  }
  int total = doc["count"] | 0, success = 0, failed = 0;
  int newVersion = doc["version"] | 0;
  Serial.printf("[Restore] Found %d template(s), DB version %d\n", total, newVersion);
  JsonArray templates = doc["templates"].as<JsonArray>();
  for (JsonObject t : templates) {
    int    slot        = t["slot"] | 0;
    String name        = t["name"].as<String>();
    String templateB64 = t["template"].as<String>();
    Serial.printf("[Restore] slot=%d  name=%s\n", slot, name.c_str());
    if (slot <= 0 || slot > 162) { failed++; continue; }
    if (templateB64.length() == 0) { failed++; continue; }
    uint8_t templateData[512];
    memset(templateData, 0, sizeof(templateData));
    int decoded = base64Decode(templateB64, templateData, 512);
    if (decoded != 512) {
      Serial.printf("[Restore] Bad decode: %d bytes\n", decoded);
      failed++; continue;
    }
    // Write template to sensor (custom packet method)
    uint8_t downCharCmd[] = {0xEF,0x01, 0xFF,0xFF,0xFF,0xFF, 0x01, 0x00,0x04, 0x09, 0x01, 0x00,0x0F};
    fpSerial.write(downCharCmd, sizeof(downCharCmd));
    delay(100);
    while (fpSerial.available()) fpSerial.read();
    int sent = 0;
    while (sent < 512) {
      int chunkSize   = min(128, 512 - sent);
      bool isLast     = (sent + chunkSize >= 512);
      uint8_t pid     = isLast ? 0x08 : 0x02;
      uint16_t pktLen = chunkSize + 2;
      uint8_t hdr[]   = {0xEF,0x01, 0xFF,0xFF,0xFF,0xFF, pid, (uint8_t)(pktLen >> 8), (uint8_t)(pktLen & 0xFF)};
      fpSerial.write(hdr, sizeof(hdr));
      fpSerial.write(templateData + sent, chunkSize);
      uint16_t chk = pid + (pktLen >> 8) + (pktLen & 0xFF);
      for (int k = 0; k < chunkSize; k++) chk += templateData[sent + k];
      fpSerial.write((uint8_t)(chk >> 8));
      fpSerial.write((uint8_t)(chk & 0xFF));
      sent += chunkSize; delay(20);
    }
    delay(200);
    while (fpSerial.available()) fpSerial.read();
    uint8_t res = finger.storeModel(slot);
    if (res == FINGERPRINT_OK) {
      Serial.printf("[Restore] Slot %d OK — %s\n", slot, name.c_str());
      success++;
    } else {
      Serial.printf("[Restore] Slot %d FAIL code=%d\n", slot, res);
      failed++;
    }
    delay(200);
  }
  Serial.printf("[Restore] Done: %d ok, %d failed\n", success, failed);
  if (success > 0 && failed == 0) {
    char msg[20]; snprintf(msg, sizeof(msg), "%d restored", success);
    showAlert("Sync Done!", msg, true); beepAsyncSingle(BEEP_ENROLL_OK);
    // Save the new version locally
    localFingerprintVersion = newVersion;
    preferences.begin("fp", false);
    preferences.putInt("version", localFingerprintVersion);
    preferences.end();
  } else if (success > 0) {
    char msg[20]; snprintf(msg, sizeof(msg), "%d ok %d fail", success, failed);
    showAlert("Partial Sync", msg, true); beepAsyncSingle(BEEP_SCAN);
  } else {
    showAlert("Sync Fail", "0 restored", false); beepAsyncSingle(BEEP_ERROR);
  }
}

