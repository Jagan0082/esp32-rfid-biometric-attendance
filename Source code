// ==================== LOOP ====================
void loop() {
  updateBuzzer();

  if (Serial.available()) {
    String cmd=Serial.readStringUntil('\n'); cmd.trim(); cmd.toLowerCase();
    if      (cmd=="restore") { Serial.println("[CMD] Restoring..."); restoreFingerprintsFromDB(); }
    else if (cmd=="status")  { printStatus(); }
    else if (cmd.length()>0) {
      Serial.println("[CMD] Unknown: "+cmd);
      Serial.println("[CMD] Available: 'restore', 'status'");
    }
  }

  if (alertShowing && millis()-alertShownAt>=ALERT_DISPLAY_MS) {
    alertShowing=false; drawIdleScreen(); updateClock();
  }

  if (millis()-lastWiFiCheck>WIFI_CHECK_INTERVAL) {
    lastWiFiCheck=millis();
    if (WiFi.status()!=WL_CONNECTED) {
      Serial.println("[WiFi] Lost — reconnecting...");
      connectWiFi(); idleScreenDrawn=false;
    }
  }

  if (!alertShowing&&!enrollActive&&!rfidEnrollActive&&
      millis()-lastClockUpdate>=CLOCK_UPDATE_INTERVAL) {
    lastClockUpdate=millis(); updateClock();
  }

  if (!enrollActive&&!rfidEnrollActive&&!alertShowing&&
      WiFi.status()==WL_CONNECTED&&
      millis()-lastEnrollPoll>=ENROLL_POLL_INTERVAL) {
    lastEnrollPoll=millis();
    checkEnrollQueue();
    if (!enrollActive) checkRfidEnrollQueue();
  }

  // NEW: periodic lightweight version check and sync
  if (!enrollActive && !rfidEnrollActive && !alertShowing &&
      WiFi.status() == WL_CONNECTED &&
      millis() - lastVersionCheck >= VERSION_CHECK_INTERVAL) {
    lastVersionCheck = millis();
    syncFingerprintTemplates();
  }

  if (millis()-lastStatusPrint>=STATUS_PRINT_INTERVAL) {
    lastStatusPrint=millis(); printStatus();
  }

  scannerLoop();

  if (eventPending&&!alertShowing&&!enrollActive&&!rfidEnrollActive) {
    IdentityEvent e=dequeueEvent();
    if (e.type!=ID_NONE) processEvent(e);
  }

  delay(10);
}
