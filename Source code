// ==================== RFID ENROLMENT (unchanged) ====================
bool doRfidEnroll(String& capturedUid) {
  printSeparator();
  Serial.printf("[RfidEnroll] Starting  name=%s\n", rfidEnrollName);
  printSeparator();
  rfid.PCD_Init(); delay(50);
  showRfidEnrollScreen("Tap card on reader");
  unsigned long t0 = millis();
  while (millis() - t0 < 45000) {
    rfid.PCD_Init(); delay(20);
    if (!rfid.PICC_IsNewCardPresent()) { delay(80); continue; }
    if (!rfid.PICC_ReadCardSerial())   { delay(80); continue; }
    String uid = "";
    for (byte i = 0; i < rfid.uid.size; i++) {
      if (rfid.uid.uidByte[i] < 0x10) uid += "0";
      uid += String(rfid.uid.uidByte[i], HEX);
    }
    uid.toUpperCase();
    rfid.PICC_HaltA(); rfid.PCD_StopCrypto1();
    capturedUid = uid;
    Serial.println("[RfidEnroll] Card tapped  UID: " + uid);
    rfid.PCD_Init();
    return true;
  }
  rfid.PCD_Init();
  Serial.println("[RfidEnroll] TIMEOUT — no card tapped");
  return false;
}

