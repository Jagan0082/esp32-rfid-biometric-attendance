// ==================== BUZZER (async) ====================
void beepAsyncSingle(int ms) {
  buzzerPattern       = BUZZ_SINGLE;
  buzzerPhaseStart    = millis();
  buzzerPhaseDuration = ms;
  digitalWrite(BUZZER_PIN, HIGH);
}

void beepAsyncDouble(int ms1, int gap, int ms2) {
  buzzerPattern       = BUZZ_DOUBLE_PHASE1;
  buzzerPhaseStart    = millis();
  buzzerPhaseDuration = ms1;
  digitalWrite(BUZZER_PIN, HIGH);
}

void updateBuzzer() {
  unsigned long now = millis();
  switch (buzzerPattern) {
    case BUZZ_SINGLE:
      if (now - buzzerPhaseStart >= (unsigned long)buzzerPhaseDuration) {
        digitalWrite(BUZZER_PIN, LOW);
        buzzerPattern = BUZZ_OFF;
      }
      break;
    case BUZZ_DOUBLE_PHASE1:
      if (now - buzzerPhaseStart >= (unsigned long)buzzerPhaseDuration) {
        digitalWrite(BUZZER_PIN, LOW);
        buzzerPattern       = BUZZ_DOUBLE_PAUSE;
        buzzerPhaseStart    = now;
        buzzerPhaseDuration = BEEP_THANKYOU_GAP;
      }
      break;
    case BUZZ_DOUBLE_PAUSE:
      if (now - buzzerPhaseStart >= (unsigned long)buzzerPhaseDuration) {
        digitalWrite(BUZZER_PIN, HIGH);
        buzzerPattern       = BUZZ_DOUBLE_PHASE2;
        buzzerPhaseStart    = now;
        buzzerPhaseDuration = BEEP_THANKYOU_2;
      }
      break;
    case BUZZ_DOUBLE_PHASE2:
      if (now - buzzerPhaseStart >= (unsigned long)buzzerPhaseDuration) {
        digitalWrite(BUZZER_PIN, LOW);
        buzzerPattern = BUZZ_OFF;
      }
      break;
    default: break;
  }
}

