  while (p != FINGERPRINT_OK && millis()-t0 < 20000) { p = finger.getImage(); delay(80); }
  if (p != FINGERPRINT_OK) { Serial.println("[Enroll] TIMEOUT image 1"); return false; }
  p = finger.image2Tz(1);
  if (p != FINGERPRINT_OK) { Serial.println("[Enroll] image2Tz(1) FAILED  code: " + String(p)); return false; }
  Serial.println("[Enroll] Image 1 OK");
  showEnrollScreen("Remove finger", 1);
  t0 = millis();
  while (finger.getImage() != FINGERPRINT_NOFINGER && millis()-t0 < 8000) delay(100);
  Serial.println("[Enroll] Finger removed"); delay(400);
  showEnrollScreen("Place finger (2/2)", 2);
  t0 = millis(); p = FINGERPRINT_NOFINGER;
  while (p != FINGERPRINT_OK && millis()-t0 < 20000) { p = finger.getImage(); delay(80); }
  if (p != FINGERPRINT_OK) { Serial.println("[Enroll] TIMEOUT image 2"); return false; }
  p = finger.image2Tz(2);
  if (p != FINGERPRINT_OK) { Serial.println("[Enroll] image2Tz(2) FAILED  code: " + String(p)); return false; }
  Serial.println("[Enroll] Image 2 OK");
  p = finger.createModel();
  if (p != FINGERPRINT_OK) { Serial.println("[Enroll] createModel FAILED  code: " + String(p)); return false; }
  p = finger.storeModel(slot);
  if (p != FINGERPRINT_OK) { Serial.printf("[Enroll] storeModel(%d) FAILED  code: %d\n", slot, p); return false; }
  Serial.printf("[Enroll] SUCCESS — stored at slot %d\n", slot);
  enrollTemplateB64 = "";
  return true;
}

void extractTemplateAfterEnroll(int slot) {
  Serial.println("[Template] Extracting slot " + String(slot) + "...");
  delay(500);
  while (fpSerial.available()) fpSerial.read();
  delay(100);
  uint8_t p = finger.loadModel(slot);
  if (p != FINGERPRINT_OK) {
    Serial.println("[Template] loadModel FAILED code=" + String(p));
    while (fpSerial.available()) fpSerial.read();
    finger.begin(57600); delay(100);
    while (fpSerial.available()) fpSerial.read();
    return;
  }
  delay(200);
  while (fpSerial.available()) fpSerial.read();
  p = finger.getModel();
  if (p != FINGERPRINT_OK) {
    Serial.println("[Template] getModel FAILED code=" + String(p));
    while (fpSerial.available()) fpSerial.read();
    finger.begin(57600); delay(100);
    while (fpSerial.available()) fpSerial.read();
    return;
  }
  uint8_t templateData[512];
  memset(templateData, 0, sizeof(templateData));
  int bytesRead = 0;
  unsigned long t0 = millis();
  while (bytesRead < 512 && millis() - t0 < 5000) {
    if (fpSerial.available()) templateData[bytesRead++] = (uint8_t)fpSerial.read();
    else delay(1);
  }
  Serial.printf("[Template] Bytes read: %d\n", bytesRead);
  if (bytesRead >= 500) {
    enrollTemplateB64 = base64Encode(templateData, bytesRead);
    Serial.printf("[Template] Encoded OK — %d chars\n", enrollTemplateB64.length());
  } else {
    Serial.println("[Template] Not enough bytes — skipping DB backup");
    enrollTemplateB64 = "";
  }
  delay(200);
  while (fpSerial.available()) fpSerial.read();
  finger.begin(57600);
  delay(200);
  while (fpSerial.available()) fpSerial.read();
  Serial.println("[Template] Sensor reinitialized — ready for scanning");
}

