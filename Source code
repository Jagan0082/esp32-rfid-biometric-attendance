// ==================== CLOCK ====================
void updateClock() {
  if (!idleScreenDrawn) drawIdleScreen();
  time_t now = time(nullptr);
  struct tm t; localtime_r(&now, &t);
  char timeStr[10], dateStr[14], ampm[4];
  int h12 = t.tm_hour % 12; if (h12 == 0) h12 = 12;
  snprintf(timeStr, sizeof(timeStr), "%02d:%02d", h12, t.tm_min);
  snprintf(ampm,    sizeof(ampm),    "%s", t.tm_hour < 12 ? "AM" : "PM");
  snprintf(dateStr, sizeof(dateStr), "%02d/%02d/%04d",
           t.tm_mday, t.tm_mon+1, t.tm_year+1900);
  bool timeChg = strcmp(timeStr, lastTimeStr) || strcmp(ampm, lastAmPm);
  bool dateChg = strcmp(dateStr, lastDateStr) != 0;
  if (timeChg) {
    int cy = MID_Y + 10;
    tft.fillRect(0, cy, SCREEN_W, 80, CLR_MID_BG);
    tft.setTextColor(CLR_CLOCK, CLR_MID_BG); tft.setTextSize(6);
    int tw = (int)strlen(timeStr)*36, tx = (SCREEN_W - tw - 50)/2;
    tft.setCursor(tx, cy+6); tft.print(timeStr);
    tft.setTextSize(3); tft.setCursor(tx+tw+6, cy+38); tft.print(ampm);
    strncpy(lastTimeStr, timeStr, sizeof(lastTimeStr));
    lastTimeStr[sizeof(lastTimeStr)-1] = '\0';
    strncpy(lastAmPm, ampm, sizeof(lastAmPm));
    lastAmPm[sizeof(lastAmPm)-1] = '\0';
  }
  if (dateChg) {
    int pw=160, ph=28, px=(SCREEN_W-pw)/2, py=MID_Y+104;
    tft.fillRect(px-4, py-4, pw+8, ph+8, CLR_MID_BG);
    tft.fillRoundRect(px, py, pw, ph, 8, CLR_DATE_BG);
    tft.setTextColor(TFT_WHITE, CLR_DATE_BG); tft.setTextSize(2);
    int dw = (int)strlen(dateStr)*12;
    tft.setCursor(px+(pw-dw)/2, py+(ph-16)/2); tft.print(dateStr);
    strncpy(lastDateStr, dateStr, sizeof(lastDateStr));
    lastDateStr[sizeof(lastDateStr)-1] = '\0';
  }
}

